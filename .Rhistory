x <- c(100, 120, 100, 180, 210, 100)
g <- growth_rate(x, k = 2)
growth_rate <- function(x, k = 1) {
# -----------------------------
# Input validation
# -----------------------------
if (!is.numeric(x)) {
stop("x must be a numeric vector")
}
n <- length(x)
if (k < 1 || k >= n) {
stop("k must be >= 1 and less than length of x")
}
# -----------------------------
# Initialize output
# -----------------------------
g <- rep(NA_real_, n)
# -----------------------------
# Compute growth rate
# -----------------------------
for (t in seq.int(k + 1, n)) {
if (!is.na(x[t]) && !is.na(x[t - k]) && x[t - k] != 0) {
g[t] <- (x[t] - x[t - k]) / x[t - k]
} else {
g[t] <- NA_real_
}
}
return(g)
}
x <- c(100, 120, 100, 180, 210, 100)
g <- growth_rate(x, k = 2)
g
y <- rep(NA, length(x))
y[3] <- 100   # chain 1
y[4] <- 180   # chain 2
apply_growth_rate(g, y, k = 2)
apply_growth_rate(g, y, k = 2) %>% growth_rate()
apply_growth_rate(g, y, k = 2) |> growth_rate()
apply_growth_rate(g, y, k = 2) |> growth_rate(k =2)
library(tidyverse)
library(RVD)
save_with_date <- function(path, filename) {
if (!dir.exists(path)) {
dir.create(path, recursive = TRUE)
}
today <- format(Sys.Date(), "%d-%m-%Y")
new_name <- paste0(today, " - ", filename)
return(file.path(path, new_name))
}
iris <- iris
write_csv(iris, save_with_date("input/", "iris.csv"))
get_latest_data <- function(path, name = NULL, ext = NULL) {
files <- list.files(path, full.names = TRUE)
file_names <- basename(files)
split_data <- strsplit(file_names, " - ")
dates <- sapply(split_data, function(x) x[1])
dataset_names <- sapply(split_data, function(x) x[2])
dataset_names_clean <- sub("\\..*$", "", dataset_names)
dates <- as.Date(dates, format = "%d-%m-%Y")
# 🔹 Filter by dataset name
if (!is.null(name)) {
idx <- grepl(name, dataset_names_clean, ignore.case = TRUE)
files <- files[idx]
dates <- dates[idx]
dataset_names_clean <- dataset_names_clean[idx]
}
# 🔹 Filter by extension
if (!is.null(ext)) {
idx <- grepl(paste0("\\.", ext, "$"), file_names, ignore.case = TRUE)
files <- files[idx]
dates <- dates[idx]
dataset_names_clean <- dataset_names_clean[idx]
}
if (length(files) == 0) {
stop("No files found matching criteria")
}
# Latest date
max_date <- max(dates, na.rm = TRUE)
idx <- which(dates == max_date)
latest_files <- files[idx]
latest_names <- dataset_names_clean[idx]
if (length(latest_files) > 1) {
ord <- order(latest_names)
return(latest_files[ord[1]])
}
return(latest_files)
}
get_latest_data("input/")
data <- get_latest_data("input/")
data <- read.csv(get_latest_data("input/"))
data
